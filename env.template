# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or .env to git

# Neon Database (postgresql connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Thirdweb (https://thirdweb.com/dashboard)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Creator wallet address that receives cUSD payments
NEXT_PUBLIC_OPERATOR_ADDRESS=0xYourWalletAddress

# Celo network: "celo" (mainnet) or "celo-alfajores" (testnet)
NEXT_PUBLIC_CELO_NETWORK=celo-alfajores

# Upstash Redis — replay-attack prevention (optional)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
